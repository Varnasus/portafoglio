# GitHub personal access token (read:user, public_repo scope).
# Used by src/lib/github.ts for the contribution graph and repo stats.
# Without it, those panels display a fallback message.
GITHUB_TOKEN=

# Resend API key. Used by src/app/api/contact/route.ts for the
# contact form. Without it, contact submissions will 500.
RESEND_API_KEY=
