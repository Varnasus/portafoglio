# Environment Variables
# Copy this file to .env.local and fill in your actual values

# ====================
# Required Configuration
# ====================

# Resend API Key for email functionality
# Get your API key from https://resend.com/api-keys
# IMPORTANT: Never commit this key to version control
RESEND_API_KEY=your_resend_api_key_here

# ====================
# Optional Configuration
# ====================

# Node Environment (development, production, test)
# Default: development
# NODE_ENV=production

# ====================
# Security Notes
# ====================
# 1. Keep this file out of version control (.gitignore)
# 2. Use different API keys for development and production
# 3. Rotate API keys regularly (every 90 days recommended)
# 4. Use environment variables in your hosting platform for production
# 5. Never share API keys in Slack, email, or other communication channels
# 6. If a key is exposed, revoke it immediately and generate a new one
